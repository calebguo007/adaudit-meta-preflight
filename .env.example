PORT=8080
META_EXECUTOR_MODE=mock

# AI provider (OpenAI-compatible). Swap freely:
#   - DeepSeek gateway (dev):   https://tokendance.space/gateway/v1  with deepseek-v4-pro
#   - Vultr Serverless (prod):  https://api.vultrinference.com/v1   with llama-3.1-70b-instruct
#   - OpenRouter Gemini:        https://openrouter.ai/api/v1        with google/gemini-2.5-flash
AI_BASE_URL=https://tokendance.space/gateway/v1
AI_API_KEY=sk-xxx
AI_MODEL=deepseek-v4-pro

# Gemini through Google Cloud Vertex AI + Application Default Credentials.
# Enable this when running in Cloud Shell, Google Cloud, or any environment with ADC configured.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=project-258a4684-a97c-421d-bac
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash
